for(i in 1:nsim){
# Mature at two years
spawners = runif(age_mat, 0.2, 0.8) # Initialize first two years then run equation
rec = c()
for(yr in 1:nyrs){
rec[yr] <- exp(ln_alpha)*spawners[yr]*exp(-beta*spawners[yr]) * exp(rnorm(1, 0, sigma))
spawners[yr+age_mat] <- rec[yr]
}
rec <- c(rec, rep(NA, age_mat))
plot(y = rec, x = spawners )
# Estimate
mod <- lm(log(rec/spawners) ~ spawners)
sum <- summary(mod)
ln_alpha_hat[i] <- (mod$coefficients[1])
beta_hat[i] <- (mod$coefficients[2])
sigma_hat[i] <- sum$sigma
}
hist(-beta_hat); abline(v = beta, col = 2)
hist(exp(ln_alpha_hat)); abline(v = exp(ln_alpha), col = 2)
hist(exp(ln_alpha_hat) + (sigma_hat^2)/2); abline(v = exp(ln_alpha), col = 2)
mean(exp(ln_alpha_hat) + (sigma_hat^2)/2)
mean(exp(ln_alpha_hat) - (sigma_hat^2)/2)
exp(ln_alpha)
