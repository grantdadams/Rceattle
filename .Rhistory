rec <- c(rec, rep(NA, age_mat))
plot(y = rec, x = spawners )
# Estimate
mod <- lm(log(rec/spawners) ~ spawners)
sum <- summary(mod)
ln_alpha_hat <- (mod$coefficients[1])
ln_alpha_hat
beta_hat <- (mod$coefficients[2])
beta_hat
ln_alpha = 1.5
beta = 1
sigma = 0.5
nyrs = 20000
age_mat = 2
# Alpha is time varying to reflect environmental processes. Beta would only change things at high-stock size.
# Mature at two years
spawners = runif(age_mat, 0.2, 0.8) # Initialize first two years then run equation
rec = c()
for(yr in 1:nyrs){
rec[yr] <- exp(ln_alpha)*spawners[yr]*exp(-beta*spawners[yr]) * exp(rnorm(1, 0, sigma))
spawners[yr+age_mat] <- rec[yr]
}
rec <- c(rec, rep(NA, age_mat))
plot(y = rec, x = spawners )
# Estimate
mod <- lm(log(rec/spawners) ~ spawners)
sum <- summary(mod)
ln_alpha_hat <- (mod$coefficients[1])
ln_alpha_hat
beta_hat <- (mod$coefficients[2])
beta_hat
