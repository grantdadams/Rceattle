for(i in 1:nsim){
# Mature at two years
spawners = runif(age_mat, 0.2, 0.8) # Initialize first two years then run equation
rec = c()
for(yr in 1:nyrs){
rec[yr] <- exp(ln_alpha)*spawners[yr]*exp(-beta*spawners[yr]) * exp(rnorm(1, 0, sigma))
spawners[yr+age_mat] <- rec[yr]
}
