ll <- lgamma(N + 1) - sum(lgamma(obs_num + 1)) +
lgamma(sum_alpha) - lgamma(N + sum_alpha) +
sum(lgamma(obs_num + alpha) - lgamma(alpha))
return(-ll)
}
